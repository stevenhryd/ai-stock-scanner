{
  "name": "ai-stock-signal-be",
  "version": "1.0.0",
  "description": "AI Stock Signal Scanner for Indonesian Stocks (BEI)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test-scan": "npm run build && ts-node test-scan.ts",
    "test-scan-build": "npm run build && node dist/test-scan.js",
    "scan": "npm run dev -- --scan",
    "clean": "rimraf dist"
  },
  "keywords": [
    "stock",
    "signal",
    "indonesia",
    "bei",
    "telegram"
  ],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.7",
    "dotenv": "^16.4.1",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.1",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
