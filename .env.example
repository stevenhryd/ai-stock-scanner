# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Capital & Risk Management
CAPITAL_AMOUNT=3000000
RISK_PER_TRADE=0.02
STOP_LOSS_PCT=0.03

# Signal Limits
MAX_SIGNALS_PER_DAY=5

# Batch Processing
BATCH_SIZE=50
CONCURRENCY_LIMIT=5

# Timezone (WIB = UTC+7)
TZ=Asia/Jakarta

# AI / Google Gemini Sentiment Analysis
GEMINI_API_KEY=your_gemini_api_key_here


# Konfigurasi Anti Rate-Limit (Sangat Aman)
ADAPTIVE_BATCHING=true
YAHOO_MAX_RETRIES=4
YAHOO_REQUEST_TIMEOUT_MS=20000
INTER_REQUEST_DELAY_MIN_MS=4000
INTER_REQUEST_DELAY_MAX_MS=6000
BATCH_DELAY_MIN_MS=15000
BATCH_DELAY_MAX_MS=20000

